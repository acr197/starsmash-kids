<?xml version="1.0" encoding="utf-8"?>
<!--
    backup_rules.xml
    ================
    Android Auto Backup and Data Extraction rules.

    StarSmash Kids stores only user preferences (sound, theme, toggle states) in
    SharedPreferences. These preferences are benign and contain no sensitive data,
    but we conservatively exclude them from cloud backup to ensure:

      1. Privacy: No child-related usage data leaves the device.
      2. Fresh start: Each installation of the app begins with sensible defaults.
      3. Simplicity: Avoids unexpected state restoration across device migrations.

    If a parent reinstalls the app, they will be presented with the default settings
    and can configure them again in under 30 seconds.

    Ref: https://developer.android.com/guide/topics/data/autobackup
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all SharedPreferences files -->
        <exclude domain="sharedpref" path="." />
        <!-- Exclude all app-private data files -->
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="cache" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Allow preferences to transfer to a new device so parents don't
             have to re-configure when upgrading phones. Comment this out
             if you prefer a completely fresh start on every install. -->
        <include domain="sharedpref" path="starsmash_settings.xml" />
    </device-transfer>
</data-extraction-rules>
