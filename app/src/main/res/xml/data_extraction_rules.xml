<?xml version="1.0" encoding="utf-8"?>
<!--
    data_extraction_rules.xml (API 31+)
    Excludes all app data from cloud backup for privacy.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="database" />
    </cloud-backup>

    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="database" />
    </device-transfer>
</data-extraction-rules>
