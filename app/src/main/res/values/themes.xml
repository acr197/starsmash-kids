<?xml version="1.0" encoding="utf-8"?>
<!--
    themes.xml
    ==========
    The base application theme. This is only used for the brief window between
    the Activity being created and Compose rendering its first frame.
    The actual Material 3 theme is applied entirely in Compose (Theme.kt).

    Note: Because the app is Compose-only with no Views, this theme is
    intentionally minimal. The "Bridge" theme pattern ensures the window
    background matches the Compose background color to avoid a flash of
    white on startup.
-->
<resources>
    <style name="Theme.StarSmashKids" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Window background matches WarmBackground from Color.kt (0xFFFFFBF0) -->
        <item name="android:windowBackground">#FFFFFBf0</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Status bar color – will be hidden by immersive mode anyway -->
        <item name="android:statusBarColor">#FFFFFBf0</item>
        <item name="android:navigationBarColor">#FFFFFBf0</item>
    </style>
</resources>
